generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  COUNSELOR
  ADMIN
}

enum InstitutionType {
  SCHOOL
  TUITION
  PARAMEDICAL
}

enum InterventionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ApplicationStage {
  LEAD
  INQUIRY
  APPLICATION_STARTED
  DOCS_PENDING
  SUBMITTED
  SHORTLISTED
  ADMITTED
  ENROLLED
}

enum ProgramMode {
  LIVE
  RECORDED
  HYBRID
}

model User {
  id                String               @id @default(cuid())
  name              String
  email             String               @unique
  className         String
  goal              String
  credits           Int                  @default(120)
  passwordHash      String
  role              Role                 @default(STUDENT)
  institutionId     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  institution       Institution?         @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  teacherProfile    TeacherProfile?
  taughtClasses     TeacherClassMap[]    @relation("TeacherClassMappings")
  studentClasses    StudentClassMap[]
  teacherTasks      InterventionTask[]   @relation("TeacherInterventions")
  studentTasks      InterventionTask[]   @relation("StudentInterventions")
  teacherNotes      TeacherNote[]        @relation("TeacherNotes")
  studentNotes      TeacherNote[]        @relation("StudentNotes")
  assignments       Assignment[]         @relation("TeacherAssignments")
  submissions       Submission[]         @relation("StudentSubmissions")
  managedPrograms   SkillProgram[]       @relation("ProgramManagers")
  applicationOwners AdmissionApplication[] @relation("ApplicationOwners")
  applicationStudent AdmissionApplication[] @relation("ApplicationStudents")
  applicationNotes  ApplicationNote[]
  careerProfiles    CareerProfile[]
  sessions          Session[]
  transactions      CreditTransaction[]
  studyHelpBookings StudyHelpBooking[]
  examAttempts      ExamAttempt[]
  courseEnrollments CourseEnrollment[]
  careerAssessments CareerAssessment[]
  auditLogs         AuditLog[]
  passwordResets    PasswordResetToken[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id           String   @id @default(cuid())
  userId       String
  delta        Int
  reason       String
  createdAt    DateTime @default(now())
  balanceAfter Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyHelpBooking {
  id          String    @id @default(cuid())
  userId      String
  planId      String
  planLabel   String
  creditsUsed Int
  slotId      String?   @unique
  tutorName   String?
  slotStartAt DateTime?
  slotEndAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  slot        TutorSlot? @relation(fields: [slotId], references: [id])
}

model TutorSlot {
  id        String           @id @default(cuid())
  planId    String
  tutorName String
  startAt   DateTime
  endAt     DateTime
  isBooked  Boolean          @default(false)
  createdAt DateTime         @default(now())
  booking   StudyHelpBooking?
}

model ExamAttempt {
  id           String    @id @default(cuid())
  userId       String
  examId       String
  examName     String
  creditsUsed  Int
  status       String    @default("started")
  scorePercent Int?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CourseEnrollment {
  id              String    @id @default(cuid())
  userId          String
  courseId        String
  courseTitle     String
  creditsUsed     Int
  progressPercent Int       @default(0)
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CareerAssessment {
  id                 String   @id @default(cuid())
  userId             String
  pathwayId          String
  pathwayTitle       String
  creditsUsed        Int
  status             String   @default("completed")
  matchScore         Int?
  reportSummary      String?
  recommendedCourses String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Institution {
  id          String             @id @default(cuid())
  name        String
  code        String             @unique
  type        InstitutionType
  state       String
  district    String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  users       User[]
  classes     TeacherClassMap[]
  applications AdmissionApplication[]
  programs    SkillProgram[]
}

model TeacherProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String?
  subjects     String
  classLevels  String
  isVerified   Boolean  @default(false)
  onboardingAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeacherClassMap {
  id            String            @id @default(cuid())
  teacherId     String
  institutionId String
  className     String
  section       String?
  subject       String
  createdAt     DateTime          @default(now())
  teacher       User              @relation("TeacherClassMappings", fields: [teacherId], references: [id], onDelete: Cascade)
  institution   Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  students      StudentClassMap[]
}

model StudentClassMap {
  id                 String          @id @default(cuid())
  studentId          String
  teacherClassMapId  String
  rollNumber         String?
  createdAt          DateTime        @default(now())
  student            User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherClassMap    TeacherClassMap @relation(fields: [teacherClassMapId], references: [id], onDelete: Cascade)
}

model InterventionTask {
  id          String             @id @default(cuid())
  teacherId   String
  studentId   String
  reasonCode  String
  summary     String
  status      InterventionStatus @default(OPEN)
  dueAt       DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  teacher     User               @relation("TeacherInterventions", fields: [teacherId], references: [id], onDelete: Cascade)
  student     User               @relation("StudentInterventions", fields: [studentId], references: [id], onDelete: Cascade)
}

model TeacherNote {
  id         String   @id @default(cuid())
  teacherId  String
  studentId  String
  note       String
  createdAt  DateTime @default(now())
  teacher    User     @relation("TeacherNotes", fields: [teacherId], references: [id], onDelete: Cascade)
  student    User     @relation("StudentNotes", fields: [studentId], references: [id], onDelete: Cascade)
}

model Assignment {
  id           String   @id @default(cuid())
  teacherId    String
  title        String
  description  String
  subject      String
  dueAt        DateTime?
  createdAt    DateTime @default(now())
  teacher      User     @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  submissions  Submission[]
}

model Submission {
  id            String   @id @default(cuid())
  assignmentId  String
  studentId     String
  status        String   @default("submitted")
  scorePercent  Int?
  submittedAt   DateTime @default(now())
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       User       @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
}

model AdmissionApplication {
  id             String           @id @default(cuid())
  institutionId  String
  studentId      String
  ownerId        String?
  stage          ApplicationStage @default(LEAD)
  targetProgram  String
  intakeYear     Int
  checklistJson  String?
  deadlineAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  institution    Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  student        User             @relation("ApplicationStudents", fields: [studentId], references: [id], onDelete: Cascade)
  owner          User?            @relation("ApplicationOwners", fields: [ownerId], references: [id], onDelete: SetNull)
  notes          ApplicationNote[]
}

model ApplicationNote {
  id             String               @id @default(cuid())
  applicationId  String
  authorId       String
  note           String
  createdAt      DateTime             @default(now())
  application    AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  author         User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model SkillProgram {
  id             String      @id @default(cuid())
  institutionId  String
  managerId      String
  title          String
  description    String
  mode           ProgramMode
  creditsCost    Int
  isPublished    Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  institution    Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  manager        User        @relation("ProgramManagers", fields: [managerId], references: [id], onDelete: Cascade)
  modules        SkillProgramModule[]
  liveSessions   LiveSession[]
}

model SkillProgramModule {
  id          String       @id @default(cuid())
  programId   String
  title       String
  assetUrl    String?
  durationMin Int?
  orderIndex  Int          @default(0)
  createdAt   DateTime     @default(now())
  program     SkillProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model LiveSession {
  id            String       @id @default(cuid())
  programId     String
  title         String
  startsAt      DateTime
  endsAt        DateTime
  capacity      Int          @default(50)
  attendance    Int          @default(0)
  replayUrl     String?
  createdAt     DateTime     @default(now())
  program       SkillProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model CareerProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  interests              String
  strengths              String
  preferredStates        String
  budgetBand             String
  targetExamTimeline     String
  psychometricSummary    String
  updatedAt              DateTime @updatedAt
  createdAt              DateTime @default(now())
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  payload    String?
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
